{
  "name": "news-forest-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:down": "node scripts/migrate.mjs down",
    "migrate:redo": "node scripts/migrate.mjs redo",
    "migrate:create": "node scripts/migrate.mjs create -j sql",
    "db:reset": "node scripts/migrate.mjs down 0 && node scripts/migrate.mjs up",
    "fetch-news": "node scripts/fetch-rss.mjs",
    "fetch-news:ai": "node scripts/fetch-rss.mjs --ai",
    "fetch-news:dry": "node scripts/fetch-rss.mjs --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/sensible": "^5.6.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "node-pg-migrate": "^7.6.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.1",
    "typescript": "~5.6.2"
  }
}
