# Neon (or any PostgreSQL 14+) connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=3001
NODE_ENV=development

# UC-01 § anonymous_hash 의 server-side salt (절대 commit 금지)
APP_HASH_SALT=please-replace-with-strong-random-string

# FE 가 dev 에서 접속하는 origin
CORS_ORIGIN=http://localhost:5173

# Anthropic Claude API (기사 AI 요약용 — fetch-rss.mjs --ai 옵션 사용 시 필요)
ANTHROPIC_API_KEY=sk-ant-...
